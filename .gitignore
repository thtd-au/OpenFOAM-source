# -----------------------------------------------------------------------------
# OpenFOAM build products
# -----------------------------------------------------------------------------
platforms/
**/lnInclude/
*.dep
*.o
*.so
*.a
*.la

# -----------------------------------------------------------------------------
# Dynamic runtime compilation
# -----------------------------------------------------------------------------
dynamicCode/
codeStream/

# -----------------------------------------------------------------------------
# Parallel decomposition
# -----------------------------------------------------------------------------
run/**/processor*/
run/**/processors*/

# Sandbox work area
run/sandbox/
# misc folder 
misc/

# -----------------------------------------------------------------------------
# Time directories and solver results
# Keep initial conditions in /0
# -----------------------------------------------------------------------------
run/**/[1-9]*/
run/**/[1-9]*.[0-9]*/
run/**/0.[0-9]*/
run/**/-[0-9]*/

# Explicitly keep initial conditions
!run/**/0/
!run/**/0/**

# -----------------------------------------------------------------------------
# Post-processing and exported data
# -----------------------------------------------------------------------------
run/**/postProcessing/
run/**/VTK/
run/**/sets/
run/**/surfaces/
run/**/logs/

# Meshes generated by blockMesh/snappyHexMesh
run/**/constant/polyMesh/

# -----------------------------------------------------------------------------
# Common generated outputs
# -----------------------------------------------------------------------------
*.foam
*.OpenFOAM
*.vtk
*.vtp
*.vtu
*.csv
*.dat
*.raw

# Visualization/media outputs
*.png
*.jpg
*.jpeg
*.mp4
*.avi

# OpenFOAM logs
log.*

# -----------------------------------------------------------------------------
# ParaView
# Keep .pvsm if visualization setup matters to the project
# -----------------------------------------------------------------------------
*.pvd

# -----------------------------------------------------------------------------
# HPC / Slurm logs
# -----------------------------------------------------------------------------
slurm-*.out
*.err

# -----------------------------------------------------------------------------
# Editor backups and OS files
# -----------------------------------------------------------------------------
*~
*.bak
*.swp
.DS_Store

# -----------------------------------------------------------------------------
# Python cache / notebooks
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
.ipynb_checkpoints/
